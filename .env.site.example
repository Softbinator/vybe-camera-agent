# =============================================================================
# vybe-camera-agent — on-site deployment env
# Copy to .env before running `docker compose -f docker-compose.site.yml up -d`.
# install.sh renders this automatically from interactive prompts.
# =============================================================================

# ------------------------------------------------------------
# NIC layout on the host. `install.sh` writes these.
# ------------------------------------------------------------
# Interface facing the internet (has the default route).
WAN_IF=eth0
# Interface dedicated to the camera LAN. Must already be configured with
# a static IP at 10.20.0.1/24 (install.sh does this via a netplan drop-in).
LAN_IF=eth1
# Camera LAN CIDR. Keep in sync with dnsmasq/dnsmasq.conf dhcp-range.
LAN_CIDR=10.20.0.0/24

# ------------------------------------------------------------
# Tailscale (sidecar container for remote access)
# Mint a reusable auth key at https://login.tailscale.com/admin/settings/keys
# Tag it as :camera-agent so you can apply ACLs.
# ------------------------------------------------------------
TS_AUTHKEY=tskey-auth-...
TS_HOSTNAME=vybe-camera-agent
TS_EXTRA_ARGS=--ssh --accept-dns=false

# ------------------------------------------------------------
# Agent → backend (same as dev .env; paste from the b2b "Generate Credential"
# dialog for this venue, and the cloud API URL).
# ------------------------------------------------------------
API_BASE_URL=https://d16rcatmaudft5.cloudfront.net
VENUE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KEYCLOAK_URL=https://d16rcatmaudft5.cloudfront.net/auth
KEYCLOAK_REALM=vybe
KEYCLOAK_CLIENT_ID=camera-agent-<venue-uuid>-<timestamp>
KEYCLOAK_CLIENT_SECRET=

# Where locally-stored chunks land (only used when storage_mode=local|both).
OUTPUT_DIR=/output
