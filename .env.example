# Copy this file to .env and fill in your credentials.
# The .env file is loaded automatically at startup via python-dotenv.
# In Docker it is passed via the env_file directive in docker-compose.yml.

# ---------------------------------------------------------------------------
# rclone S3 credentials
# The remote name prefix (S3VYBE) must match rclone_remote in config.yaml,
# uppercased. e.g. rclone_remote: s3vybe → prefix: S3VYBE
# ---------------------------------------------------------------------------

RCLONE_CONFIG_S3VYBE_TYPE=s3
RCLONE_CONFIG_S3VYBE_PROVIDER=AWS
RCLONE_CONFIG_S3VYBE_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
RCLONE_CONFIG_S3VYBE_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY
RCLONE_CONFIG_S3VYBE_REGION=eu-central-1
# Skip bucket existence check — required when uploading to a pre-existing bucket
# (prevents rclone from calling CreateBucket, which fails with region errors)
RCLONE_CONFIG_S3VYBE_NO_CHECK_BUCKET=true

# Optional: use a custom endpoint for S3-compatible providers (MinIO, Wasabi, etc.)
# RCLONE_CONFIG_S3VYBE_ENDPOINT=https://s3.example.com
