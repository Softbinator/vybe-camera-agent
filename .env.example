# Venue this camera agent belongs to (UUID from vybe-backend)
VENUE_ID=your-venue-uuid-here

# vybe-backend API base URL
API_BASE_URL=http://api:3000

# Keycloak service account credentials (generated from the B2B UI or Milestone 4)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=vybe-realm
KEYCLOAK_CLIENT_ID=camera-agent-your-venue-uuid
KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# RTSP stream URLs for each camera (referenced from config.yaml)
CAMERA_ENTRANCE_RTSP_URL=rtsp://admin:password@192.168.1.10:554/stream1
